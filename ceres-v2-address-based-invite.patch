-// ─────────────────────────────────────────────────────
-// Write Functions
-// ─────────────────────────────────────────────────────
+// ───── v2: Address-based Invite (no DID) ─────
+
+/**
+ * Read the current invite fee (wei).
+ */
+export function useInviteFee() {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'inviteFee',
+  })
+}
+
+/**
+ * Check whether the invite fee is enabled.
+ */
+export function useInviteFeeEnabled() {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'inviteFeeEnabled',
+  })
+}
+
+/**
+ * Read the inviter address for an invitee.
+ */
+export function useInviterAddress(invitee: `0x${string}` | undefined) {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'getInviter',
+    args: invitee ? [invitee] : undefined,
+    query: { enabled: !!invitee },
+  })
+}
+
+/**
+ * Read the list of addresses invited by an inviter.
+ */
+export function useInvitees(inviter: `0x${string}` | undefined) {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'getInvitees',
+    args: inviter ? [inviter] : undefined,
+    query: { enabled: !!inviter },
+  })
+}
+
+/**
+ * Check if an address has been invited.
+ */
+export function useIsInvited(invitee: `0x${string}` | undefined) {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'isInvited',
+    args: invitee ? [invitee] : undefined,
+    query: { enabled: !!invitee },
+  })
+}
+
+/**
+ * Get the invite count for an address.
+ */
+export function useInviteCount(inviter: `0x${string}` | undefined) {
+  return useReadContract({
+    ...registryContract,
+    functionName: 'getInviteCount',
+    args: inviter ? [inviter] : undefined,
+    query: { enabled: !!inviter },
+  })
+}
+
+// ───── Write Functions ─────
+
+/**
+ * Authorize an invite (no DID mint).
+ * When inviteFeeEnabled, the caller must send msg.value >= inviteFee.
+ * Caller is the invitee. Only needs the inviter address.
+ * Pass `value` (in wei) to pay the invite fee.
+ */
+export function useAuthorizeInvite() {
+  const { writeContractAsync } = useWriteContract()
+
+  return useCallback(
+    async (inviter: `0x${string}`, value?: bigint) => {
+      return writeContractAsync({
+        ...registryContract,
+        functionName: 'authorizeInvite',
+        args: [inviter],
+        value,
+      })
+    },
+    [writeContractAsync],
+  )
+}
 
