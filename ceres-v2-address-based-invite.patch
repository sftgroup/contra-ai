+
+// ───── v2: Address-based invite (no DID required) ─────
+
+/**
+ * Get the address that invited this invitee.
+ * Returns `undefined` if not invited.
+ */
+export async function getInviterAddress(
+  invitee: `0x${string}`,
+  publicClient: PublicClient,
+): Promise<`0x${string}` | undefined> {
+  const result = await publicClient.readContract({
+    address: CERES_REGISTRY_ADDRESS,
+    abi: CeresRegistry_ABI,
+    functionName: 'getInviter',
+    args: [invitee],
+  })
+  const addr = result as `0x${string}`
+  return addr !== '0x0000000000000000000000000000000000000000' ? addr : undefined
+}
+
+/**
+ * Get the list of addresses invited by an inviter.
+ */
+export async function getInvitees(
+  inviter: `0x${string}`,
+  publicClient: PublicClient,
+): Promise<`0x${string}`[]> {
+  const result = await publicClient.readContract({
+    address: CERES_REGISTRY_ADDRESS,
+    abi: CeresRegistry_ABI,
+    functionName: 'getInvitees',
+    args: [inviter],
+  })
+  return result as `0x${string}`[]
+}
+
+/**
+ * Check whether an address has been invited.
+ */
+export async function isInvited(
+  invitee: `0x${string}`,
+  publicClient: PublicClient,
+): Promise<boolean> {
+  const result = await publicClient.readContract({
+    address: CERES_REGISTRY_ADDRESS,
+    abi: CeresRegistry_ABI,
+    functionName: 'isInvited',
+    args: [invitee],
+  })
+  return result as boolean
+}
+
+/**
+ * Get the invite count for an address.
+ */
+export async function getInviteCountAddr(
+  inviter: `0x${string}`,
+  publicClient: PublicClient,
+): Promise<bigint> {
+  const result = await publicClient.readContract({
+    address: CERES_REGISTRY_ADDRESS,
+    abi: CeresRegistry_ABI,
+    functionName: 'getInviteCount',
+    args: [inviter],
+  })
+  return result as bigint
+}
